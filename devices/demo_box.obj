# demo_box.obj — embedded default for system/machine/demo_box.obj.
#
# Consumed at boot by fs/vfs.cpp (register_embedded_defaults), looked
# up by render/obj_registry.cpp when the mill3 kinematic TSV
# (machines/kinematic_mill3.tsv) resolves the base body's
# obj_file=demo_box.obj.
#
# Geometry: 1-unit cube centered on the origin (matches the unit
# convention used by the companion demo_part.stl tetrahedron).
o demo_box
v -0.5 -0.5 -0.5
v -0.5 -0.5  0.5
v -0.5  0.5 -0.5
v -0.5  0.5  0.5
v  0.5 -0.5 -0.5
v  0.5 -0.5  0.5
v  0.5  0.5 -0.5
v  0.5  0.5  0.5
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
f 1//1 2//1 4//1 3//1
f 5//2 7//2 8//2 6//2
f 1//3 5//3 6//3 2//3
f 3//4 4//4 8//4 7//4
f 1//5 3//5 7//5 5//5
f 2//6 6//6 8//6 4//6
